{
    "name": "phpmlkit/sndfile",
    "description": "Low-level libsndfile + libsamplerate bindings for PHP via FFI",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kyrian Obikwelu"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-ffi": "*",
        "phpmlkit/ndarray": "^2.0",
        "codewithkyrian/platform-package-installer": "^2.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhpMlKit\\Sndfile\\": "src/"
        },
        "files": [
            "src/Functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PhpMlKit\\Sndfile\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test:pretty": "./vendor/bin/phpunit --testdox",
        "cs:fix": "./vendor/bin/php-cs-fixer fix",
        "cs:check": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint": "./vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "codewithkyrian/platform-package-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
